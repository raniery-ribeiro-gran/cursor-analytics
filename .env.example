# SQLite (arquivo local)
SQLITE_PATH=./data/cursor-analytics.db

# Autenticação (obrigatório) — uma única definição; não duplique a variável
AUTH_SECRET=defina-uma-chave-longa-e-aleatoria-com-minimo-16-caracteres

# SMTP para envio do código de login (sem SMTP, o token aparece no log do servidor)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=raniery@raniery.com.br
SMTP_PASSWORD=
SMTP_FROM=raniery@raniery.com.br
